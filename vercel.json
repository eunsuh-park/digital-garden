{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/notion-sections", "destination": "/api/notion-locations" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "redirects": [
    { "source": "/favicon.ico", "destination": "/favicon.svg", "permanent": false }
  ]
}
