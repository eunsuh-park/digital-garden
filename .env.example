# ====================================================
# 환경변수 템플릿 (.env.example)
# ※ 이 파일은 git에 커밋됩니다. 실제 값을 절대 넣지 마세요.
#
# 사용법:
#   로컬 개발  → .env.local 파일을 만들고 아래 변수를 채워넣으세요
#   프로덕션   → Vercel 대시보드 > Settings > Environment Variables 에 등록
# ====================================================

# ------ Notion API ------
# Notion Integration 발급 시크릿 (서버 전용: Vercel/Worker 런타임만 읽음)
NOTION_API_KEY=

# DB 1: 구역(Locations)
NOTION_DATABASE_ID_SECTIONS=

# DB 2: 작업(Tasks)
NOTION_DATABASE_ID_TASKS=

# DB 3: 식물(Plants)
NOTION_DATABASE_ID_PLANTS=

# ------ Supabase 클라이언트 ------
# VITE_ 접두사가 있으면 브라우저 번들에 포함됩니다 (anon key는 공개 가능)
# Supabase 대시보드 > Project Settings > API 에서 확인
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=

# ------ Supabase CLI / CI (서버 전용) ------
# Supabase 계정 대시보드 > Account > Access Tokens
SUPABASE_ACCESS_TOKEN=
# Supabase 대시보드 > Project Settings > General > Reference ID
SUPABASE_PROJECT_REF=

# ------ API 기원 ------
# GitHub Pages 등 정적 호스팅에서 Notion API를 호출할 때 필요
# 로컬 개발에서는 Vite 프록시(localhost:8787)가 처리하므로 불필요
# VITE_API_ORIGIN=https://<your-project>.vercel.app
VITE_API_ORIGIN=
