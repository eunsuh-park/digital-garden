# ====================================================
# 환경변수 템플릿 (.env.example)
# ※ 이 파일은 git에 커밋됩니다. 실제 값을 절대 넣지 마세요.
#
# 사용법 (Vite):
#   npm run dev (mode=development) 시 로드 순서: .env → .env.local → .env.development → .env.development.local
#   npm run build (mode=production) 시: .env → .env.local → .env.production → .env.production.local
#   (같은 키는 뒤 파일이 앞을 덮어씁니다. 배포 호스트에는 Vercel 등 환경 변수로 등록)
# ====================================================

# ------ Notion API (레거시 — 앱은 Supabase garden_* 사용, 프론트는 Notion을 호출하지 않음) ------
# Vercel api/notion-*.js 등 구 서버리스만 쓸 때
NOTION_API_KEY=
NOTION_DATABASE_ID_SECTIONS=
NOTION_DATABASE_ID_TASKS=
NOTION_DATABASE_ID_PLANTS=

# ------ Supabase 클라이언트 ------
# vite.config의 envPrefix로 브라우저 번들에 포함됩니다 (anon / publishable만, service_role 금지)
# 대시보드 > Project Settings > API: Project URL 과 같은 프로젝트의 "anon" / "publishable" 키를 쓰세요.
# sbp_ 계정 토큰·DB 비밀번호 넣으면 "Invalid API key" / 401 이 납니다.
#
# [Supabase 프로젝트를 로컬용 / 프로덕션용 두 개 쓰는 경우]
# - npm run dev → .env.local 에 "로컬(또는 dev) 전용 프로젝트"의 URL+키만 넣는다 (한 쌍).
# - 배포 또는 vite build → 호스트(Vercel 등) 또는 .env.production 에 "프로덕션 프로젝트"의 URL+키 (한 쌍).
# - URL은 https://<ref>.supabase.co 이고, 그 ref와 키는 반드시 같은 프로젝트 설정 화면에서 복사.
# - 다른 프로젝트의 키를 넣으면 서버가 정확히 "Invalid API key" 로 거절한다.
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=
# 하위 호환: 기존 프로젝트는 아래 이름도 동작합니다
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=

# ------ 개발 전용: Supabase 없이 UI 테스트 (npm run dev + development 모드만) ------
# true 이면 인메모리 목 인증·프로젝트 데이터 사용. 프로덕션 빌드에서는 무시됩니다.
USE_MOCK=false
# 또는 VITE_USE_MOCK=true

# ------ Supabase CLI / CI (서버 전용) ------
# Supabase 계정 대시보드 > Account > Access Tokens (Personal Access Token, 접두사 sbp_ )
# ※ SUPABASE_ANON_KEY(eyJ...) 와 다릅니다. CLI link / db query 에는 sbp_ 토큰을 넣으세요.
SUPABASE_ACCESS_TOKEN=
# Supabase 대시보드 > Project Settings > General > Reference ID
SUPABASE_PROJECT_REF=

# ------ API 기원 (레거시 Notion 프록시 등) ------
# 구역·할 일·식물은 Supabase 직접 호출이므로 일반적으로 불필요
# VITE_API_ORIGIN=https://<your-project>.vercel.app
VITE_API_ORIGIN=
